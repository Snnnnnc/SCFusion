# ================
# 系统文件
# ================
.DS_Store         # macOS 桌面服务存储
Thumbs.db         # Windows 缩略图缓存
desktop.ini       # Windows 文件夹配置

# ================
# 开发环境
# ================
.env              # 环境变量文件
*.local           # 本地覆盖配置
.venv/            # Python 虚拟环境

# ================
# 构建产物
# ================
/build/           # 构建输出目录
/dist/            # 分发包目录
*.exe             # 可执行文件
*.dll             # 动态链接库

# ================
# 日志文件
# ================
*.log             # 所有日志文件
logs/             # 日志目录
npm-debug.log*    # npm 调试日志

# ================
# IDE 配置文件
# ================
.idea/            # JetBrains IDE
.vscode/          # VS Code 配置
*.suo             # Visual Studio 用户选项
*.iml             # IntelliJ 模块文件